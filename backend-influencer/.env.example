# 环境变量配置模板
# 复制此文件为 .env 并修改实际值

# ============================================================
# Database Configuration
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=athluna_kms_db
DB_USER=root
DB_PASSWORD=your_secure_password_here

# ============================================================
# Redis Configuration
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================
# Security Configuration
# ============================================================
JWT_SECRET=your-256-bit-secret-key-change-in-production
ENCRYPTION_MASTER_KEY=your-32-byte-encryption-key-here

# ============================================================
# Storage Configuration
# ============================================================
STORAGE_TYPE=LOCAL
STORAGE_BASE_PATH=D:/content-files
STORAGE_PUBLIC_URL=http://localhost:8082/influencer-api/v1/files

# For S3 storage (optional)
# STORAGE_TYPE=S3
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name
# CDN_DOMAIN=https://cdn.your-domain.com

# ============================================================
# CORS Configuration
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# For production
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ============================================================
# Server Configuration
# ============================================================
SERVER_PORT=8082

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
